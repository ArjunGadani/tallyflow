# ============================================================================
# TallyFlow environment — copy to .env and fill. NEVER commit .env.
# ============================================================================

# --- Groq (LLM: classify / extract / categorize ONLY) ---
GROQ_API_KEY=

# --- Model IDs (the ONE place; Groq rotates models — §0). Override per-env. ---
MODEL_CLASSIFY=llama-3.3-70b-versatile
MODEL_EXTRACT_TEXT=llama-3.3-70b-versatile
MODEL_EXTRACT_VISION=meta-llama/llama-4-scout-17b-16e-instruct
MODEL_CHAT=llama-3.3-70b-versatile      # TallyChat tool-calling model
# Validate configured models against Groq /models at startup (warn-only).
VALIDATE_MODELS_ON_STARTUP=false

# --- TallyChat (read-only assistant) ---
# "true" on a public/unauthenticated deploy = scripted answers, NO Groq call.
CHAT_DEMO_MODE=false
CHAT_DAILY_SPEND_CALLS=2000             # hard daily Groq-call cap (fails closed)
CHAT_RATE_LIMIT_PER_MIN=20             # per-client-IP throttle

# --- Storage: Supabase (reuse existing project; mind 2-project free limit) ---
SUPABASE_URL=
SUPABASE_SERVICE_KEY=
SUPABASE_DB_URL=                  # direct Postgres conn string — for ATOMIC store (R5)
SUPABASE_STORAGE_BUCKET=tallyflow-originals
# Backend defaults to a LOCAL SQLite stub when SUPABASE_URL is unset (dev).
STORE_BACKEND=auto                # auto | sqlite | supabase

# --- Base currency + FX ---
BASE_CURRENCY=GBP
FX_SOURCE=frankfurter             # frankfurter (ECB, historical, no key) | static
FX_STATIC_RATES=                  # optional JSON e.g. {"USD":0.79,"EUR":0.85} (fallback)

# --- Confidence / reconciliation thresholds (deterministic — §7, R12) ---
CONFIDENCE_REVIEW_THRESHOLD=0.75  # overall below -> needs_review
TOTALS_TOLERANCE_ABS=0.05         # absolute money tolerance for totals reconcile
TOTALS_TOLERANCE_PCT=0.01         # 1% relative tolerance
# Revision-vs-duplicate band (R2): delta within = duplicate; above = revision.
REVISION_TOLERANCE_ABS=0.05
REVISION_TOLERANCE_PCT=0.01
VENDOR_FUZZY_THRESHOLD=88         # rapidfuzz score 0..100 for vendor match

# --- Reliability ---
RETRY_MAX_TRIES=4
RETRY_BASE_DELAY_SEC=2            # exponential backoff base

# --- Email ingestion (IMAP) — Phase 7 ---
IMAP_HOST=imap.gmail.com
IMAP_USER=
IMAP_PASSWORD=                    # Gmail 16-char app password (no spaces)
IMAP_FOLDER=INBOX

# --- Delivery — Phase 8 ---
SLACK_WEBHOOK=
# send via Resend OR SMTP (pick one)
RESEND_API_KEY=
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
DIGEST_TO=
DIGEST_FROM=tallyflow@example.com

# --- Dashboard / CORS ---
CORS_ORIGIN=http://localhost:5173
DASHBOARD_URL=http://localhost:5173
