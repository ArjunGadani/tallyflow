# What NOT to upload to Cloud Build when running `gcloud run deploy --source .`
# Keeps secrets out of the build context and the upload small/fast.
.git/
.github/
.venv/
venv/
__pycache__/
*.pyc

# secrets — never ship to the build
.env
.env.*
*.env
*.env.yaml
cloudrun.env.yaml

# frontend: source IS needed (Docker stage 1 builds it); skip deps + prior build
node_modules/
dashboard/node_modules/
dashboard/dist/
dashboard/.vite/

# local-only data
backend/local_storage/
backend/.tallyflow_local.db
sample_docs/real/
*.md
