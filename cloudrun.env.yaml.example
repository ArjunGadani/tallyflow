# Copy to cloudrun.env.yaml (gitignored) and fill in. Passed to Cloud Run with:
#   gcloud run deploy tallyflow-api --source . --env-vars-file cloudrun.env.yaml ...
# A YAML file (not --set-env-vars) avoids comma/special-char issues in the DB URL.

# --- store: prod = Supabase ---
STORE_BACKEND: "supabase"
SUPABASE_URL: "https://YOUR-PROJECT-REF.supabase.co"
SUPABASE_SERVICE_KEY: "sb_secret_xxxxxxxxxxxxxxxxxxxxx"
SUPABASE_DB_URL: "postgresql://postgres:PASSWORD@db.YOUR-PROJECT-REF.supabase.co:5432/postgres"
SUPABASE_STORAGE_BUCKET: "tallyflow-originals"

# --- LLM ---
GROQ_API_KEY: "gsk_xxxxxxxxxxxxxxxxxxxxx"

# --- money / FX ---
BASE_CURRENCY: "USD"
FX_SOURCE: "frankfurter"

# --- the API serves the dashboard; set these to the deployed origin ---
CORS_ORIGIN: "https://YOUR-DASHBOARD-URL"
DASHBOARD_URL: "https://YOUR-DASHBOARD-URL"   # used in digest email/Slack links — NOT localhost in prod

# --- TallyChat (read-only assistant) ---
# SECURITY: on a PUBLIC, unauthenticated URL set this "true" so /api/chat serves
# scripted answers with NO Groq call (no anonymous LLM cost/abuse). Leave "false"
# only behind auth, where you want the live tool-calling assistant.
CHAT_DEMO_MODE: "false"
# MODEL_CHAT: "llama-3.3-70b-versatile"     # override if Groq rotates the model
# CHAT_DAILY_SPEND_CALLS: "2000"            # hard daily Groq-call cap (fails closed)
# CHAT_RATE_LIMIT_PER_MIN: "20"             # per-client-IP throttle

# --- polling: OFF on Cloud Run. It scales to zero, so the in-process poller
#     can't run reliably; the hourly GitHub Actions cron does ingestion instead. ---
AUTO_POLL: "false"
